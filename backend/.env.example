# ─────────────────────────────────────────────────────────────
# Arvion Backend — environment template. Copy to `.env` and fill in.
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Prisma).
DATABASE_URL="postgresql://user:password@localhost:5432/arvion?schema=public"

# Redis — used for checkout stock-reservation locks & reservation timeouts.
REDIS_URL="redis://localhost:6379"

# JWT signing secret. MUST be a long random string in production.
# Generate one with:  openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret"

# ── Razorpay (get these from https://dashboard.razorpay.com) ──
# Use rzp_test_* keys while developing, rzp_live_* only in production.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Set this to the secret you configure on the Razorpay webhook (Dashboard →
# Settings → Webhooks). The webhook endpoint is  POST /orders/webhook.
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Comma-separated list of allowed frontend origins for CORS.
ALLOWED_ORIGINS="http://localhost:3000"

# Port the API listens on (defaults to 4001).
PORT="4001"

# ── First admin account (created/updated by `prisma db seed`) ──
# The ONLY way to provision an admin — public registration can never self-elevate.
ADMIN_EMAIL="admin@arvion.com"
ADMIN_PASSWORD="use-a-strong-password"
ADMIN_NAME="Arvion Admin"
